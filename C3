<script>

let score=0;

function check(element,correct,ans){

let options=element.parentElement.children;

for(let i=0;i<options.length;i++){
options[i].style.pointerEvents="none";
}

if(correct){

element.classList.add("correct");
score++;

}
else{

element.classList.add("wrong");

for(let i=0;i<options.length;i++){

if(options[i].getAttribute("onclick").includes("true")){

options[i].classList.add("correct");

}

}

}

element.parentElement.nextElementSibling.innerHTML="Answer : "+ans;

document.getElementById("score").innerText=score;

}


function shuffleQuestions(){

let container=document.getElementById("quizContainer");

let questions=[...container.children];

questions.sort(()=>Math.random()-0.5);

container.innerHTML="";

questions.forEach(q=>container.appendChild(q));

}


function toggleTheme(){

document.body.classList.toggle("light");

}

</script>

